{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/server.js" },
    { "source": "/profesor/login", "destination": "/server.js" },
    { "source": "/login_administrador", "destination": "/server.js" },
    { "source": "/admin/dashboard", "destination": "/server.js" },
    { "source": "/admin/docentes", "destination": "/server.js" },
    { "source": "/admin/alertas", "destination": "/server.js" },
    { "source": "/admin/mensajes", "destination": "/server.js" },
    { "source": "/estudiante/dashboard", "destination": "/server.js" },
    { "source": "/maestro/dashboard", "destination": "/server.js" },
    { "source": "/seleccion-rol", "destination": "/server.js" },
    { "source": "/", "destination": "/server.js" },
    { "source": "/(.*)", "destination": "/server.js" }
  ]
}
{
  "version": 2,
  "routes": [
    { "src": "/admin/mensajes", "dest": "/api/mensajes.js" }
  ]
}